{
  "name": "critical-gate-vscode",
  "displayName": "Critical-Gate",
  "description": "Repository-aware diff integrity diagnostics for AI-generated code changes.",
  "version": "2.9.0",
  "publisher": "criticaldeveloper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/criticaldeveloper/critical-gate.git"
  },
  "homepage": "https://github.com/criticaldeveloper/critical-gate#readme",
  "bugs": {
    "url": "https://github.com/criticaldeveloper/critical-gate/issues"
  },
  "type": "module",
  "galleryBanner": {
    "color": "#0B1220",
    "theme": "dark"
  },
  "icon": "resources/icon.png",
  "keywords": [
    "ai",
    "ai agents",
    "codex",
    "diagnostics",
    "diff integrity",
    "quality-gate",
    "code-review",
    "developer tools",
    "critical developer"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Linters",
    "Testing"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Critical Gate can show existing diagnostics in Restricted Mode, but running repository diffs requires workspace trust and local git access."
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Critical Gate diagnostics depend on a local workspace, git repository, and CLI path. Virtual workspaces may not provide enough filesystem access to run checks."
    }
  },
  "main": "./dist/extensions/vscode/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "criticalGate",
          "title": "Critical Gate",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "criticalGate": [
        {
          "id": "criticalGate.dashboard",
          "name": "Gate Runs",
          "type": "webview"
        },
        {
          "id": "criticalGate.analysisTree",
          "name": "Analysis"
        }
      ]
    },
    "commands": [
      {
        "command": "criticalGate.runCheck",
        "title": "Critical Gate: Run Check"
      },
      {
        "command": "criticalGate.showReport",
        "title": "Critical Gate: Show Report"
      },
      {
        "command": "criticalGate.clearDiagnostics",
        "title": "Critical Gate: Clear Diagnostics"
      },
      {
        "command": "criticalGate.openSettings",
        "title": "Critical Gate: Open Settings"
      },
      {
        "command": "criticalGate.initializeAgentInstructions",
        "title": "Critical Gate: Initialize Agent Instructions"
      },
      {
        "command": "criticalGate.initializeRepository",
        "title": "Critical Gate: Initialize Repository",
        "icon": "$(tools)"
      },
      {
        "command": "criticalGate.openEvidence",
        "title": "Critical Gate: Open Evidence"
      },
      {
        "command": "criticalGate.copyRepair",
        "title": "Critical Gate: Copy Repair Prompt"
      },
      {
        "command": "criticalGate.openExistingSolution",
        "title": "Critical Gate: Open Existing Solution"
      },
      {
        "command": "criticalGate.openExpectedCompanion",
        "title": "Critical Gate: Open Expected Companion"
      },
      {
        "command": "criticalGate.acceptBlastRadiusExpansion",
        "title": "Critical Gate: Accept Blast-Radius Expansion"
      },
      {
        "command": "criticalGate.openClusterReport",
        "title": "Critical Gate: Open Cluster Report"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "criticalGate.initializeRepository",
          "when": "view == criticalGate.dashboard",
          "group": "navigation"
        },
        {
          "command": "criticalGate.initializeRepository",
          "when": "view == criticalGate.analysisTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "criticalGate.openEvidence",
          "when": "view == criticalGate.analysisTree && viewItem == criticalGateFinding",
          "group": "inline"
        },
        {
          "command": "criticalGate.copyRepair",
          "when": "view == criticalGate.analysisTree && viewItem == criticalGateFinding",
          "group": "inline"
        },
        {
          "command": "criticalGate.openExistingSolution",
          "when": "view == criticalGate.analysisTree && viewItem =~ /criticalGateExistingSolution/",
          "group": "navigation"
        },
        {
          "command": "criticalGate.openExpectedCompanion",
          "when": "view == criticalGate.analysisTree && viewItem =~ /criticalGateExpectedCompanion/",
          "group": "navigation"
        },
        {
          "command": "criticalGate.openClusterReport",
          "when": "view == criticalGate.analysisTree && viewItem =~ /criticalGateClusterReport/",
          "group": "navigation"
        },
        {
          "command": "criticalGate.acceptBlastRadiusExpansion",
          "when": "view == criticalGate.analysisTree && viewItem =~ /criticalGateBlastRadius/",
          "group": "2_accept"
        }
      ]
    },
    "configuration": {
      "title": "Critical Gate",
      "properties": {
        "criticalGate.task": {
          "type": "string",
          "default": "",
          "description": "Task intent to pass to Critical Gate. When empty, the extension asks before running."
        },
        "criticalGate.base": {
          "type": "string",
          "default": "",
          "description": "Optional git base ref or SHA for Critical Gate."
        },
        "criticalGate.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a custom Critical Gate CLI. Leave empty to use the analyzer bundled with the extension."
        },
        "criticalGate.refreshMode": {
          "type": "string",
          "enum": [
            "manual",
            "onSave"
          ],
          "default": "manual",
          "description": "Controls when Critical Gate refreshes diagnostics. Manual runs only from the command; onSave also runs after explicit file saves."
        },
        "criticalGate.refreshDebounceMs": {
          "type": "number",
          "default": 1200,
          "minimum": 0,
          "description": "Debounce delay before running Critical Gate after a file save when refreshMode is onSave."
        }
      }
    }
  }
}
