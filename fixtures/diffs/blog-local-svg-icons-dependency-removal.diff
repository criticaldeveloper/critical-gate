diff --git a/src/components/Icon.astro b/src/components/Icon.astro
new file mode 100644
index 0000000..c7e79a0
--- /dev/null
+++ b/src/components/Icon.astro
@@ -0,0 +1,57 @@
+---
+type IconName =
+  | "arrow-back"
+  | "arrow-forward"
+  | "arrow-outward"
+  | "bolt"
+  | "check-circle"
+  | "dataset"
+  | "grid-view"
+  | "psychology"
+  | "timer"
+  | "view-list";
+
+interface Props {
+  name: IconName;
+  class?: string;
+  label?: string;
+}
+
+const { name, class: className, label } = Astro.props;
+const ariaHidden = label ? undefined : "true";
+
+const iconPaths: Record<IconName, string> = {
+  "arrow-back":
+    '<path d="M19 12H5"/><path d="m12 5-7 7 7 7"/>',
+  "arrow-forward":
+    '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
+  "arrow-outward":
+    '<path d="M7 17 17 7"/><path d="M8 7h9v9"/>',
+  bolt: '<path d="m13 2-9 12h7l-1 8 9-12h-7l1-8Z"/>',
+  "check-circle":
+    '<path d="M21 12a9 9 0 1 1-5.27-8.2"/><path d="m9 12 2 2 7-7"/>',
+  dataset:
+    '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 8h3v3H8z"/><path d="M13 8h3v3h-3z"/><path d="M8 13h3v3H8z"/><path d="M13 13h3v3h-3z"/>',
+  "grid-view":
+    '<rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/>',
+  psychology:
+    '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.74V16h8v-1.26A7 7 0 0 0 12 2Z"/><path d="M9.5 9.5h.01"/><path d="M14.5 9.5h.01"/><path d="M10 13c1.4 1 2.6 1 4 0"/>',
+  timer:
+    '<path d="M10 2h4"/><path d="M12 14V8"/><path d="M4.93 4.93 7.05 7.05"/><circle cx="12" cy="14" r="8"/>',
+  "view-list":
+    '<path d="M8 6h12"/><path d="M8 12h12"/><path d="M8 18h12"/><path d="M4 6h.01"/><path d="M4 12h.01"/><path d="M4 18h.01"/>',
+};
+---
+
+<svg
+  class:list={["site-icon", className]}
+  viewBox="0 0 24 24"
+  fill="none"
+  stroke="currentColor"
+  stroke-width="2"
+  stroke-linecap="round"
+  stroke-linejoin="round"
+  aria-hidden={ariaHidden}
+  aria-label={label}
+  set:html={iconPaths[name]}
+/>
